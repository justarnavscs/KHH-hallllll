# Clinic & Shop Hybrid Platform - Firebase Environment Credentials
# Copy this file to '.env' and fill in your actual credentials.
# Vite automatically prefix-checks these with VITE_ to expose them to your client bundle.

VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN
VITE_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID

# 100% Free Background WhatsApp Web Bridge Credentials
# Add your deployed Render/Railway service URL and a secure API key
VITE_WHATSAPP_BRIDGE_URL=https://your-whatsapp-bridge.onrender.com
VITE_WHATSAPP_BRIDGE_API_KEY=your_secure_bridge_api_key_here

